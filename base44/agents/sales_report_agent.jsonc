      "allowed_operations": [
        "read"
      ]
    }
  ],
  "whatsapp_greeting": "\u0645\u0631\u062d\u0628\u0627\u064b! \u0623\u0646\u0627 \u0645\u0633\u0627\u0639\u062f \u062a\u0642\u0627\u0631\u064a\u0631 \u0627\u0644\u0645\u0628\u064a\u0639\u0627\u062a \u0644\u0634\u0631\u0643\u0629 \u063a\u0632\u0627\u0631\u0629 \u0644\u0644\u062a\u062c\u0627\u0631\u0629 \u0648\u0627\u0644\u062a\u0633\u0648\u064a\u0642. \u064a\u0645\u0643\u0646\u0646\u064a \u0645\u0633\u0627\u0639\u062f\u062a\u0643 \u0641\u064a \u062a\u062d\u0644\u064a\u0644 \u0628\u064a\u0627\u0646\u0627\u062a \u0627\u0644\u0645\u0628\u064a\u0639\u0627\u062a \u0648\u062a\u0648\u0644\u064a\u062f \u062a\u0642\u0627\u0631\u064a\u0631 \u0645\u062e\u0635\u0635\u0629. \u0645\u0627 \u0627\u0644\u0630\u064a \u062a\u0648\u062f \u0645\u0639\u0631\u0641\u062a\u0647 \u0627\u0644\u064a\u0648\u0645\u061f",
  "name": "sales_report_agent"
}