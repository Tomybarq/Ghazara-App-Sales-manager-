      "description": "\u0627\u0633\u0645 \u0627\u0644\u0645\u0648\u0638\u0641"
    },
    "phone": {
      "type": "string",
      "description": "\u0631\u0642\u0645 \u0627\u0644\u062c\u0648\u0627\u0644"
    },
    "email": {
      "type": "string",
      "description": "\u0627\u0644\u0628\u0631\u064a\u062f \u0627\u0644\u0625\u0644\u0643\u062a\u0631\u0648\u0646\u064a"
    },
    "position": {
      "type": "string",
      "enum": [
        "\u0645\u0646\u062f\u0648\u0628 \u0645\u0628\u064a\u0639\u0627\u062a",
        "\u0645\u0634\u0631\u0641 \u0645\u0628\u064a\u0639\u0627\u062a",
        "\u0645\u062f\u064a\u0631 \u0641\u0631\u064a\u0642",
        "\u0645\u062f\u064a\u0631 \u0645\u0646\u0637\u0642\u0629"
