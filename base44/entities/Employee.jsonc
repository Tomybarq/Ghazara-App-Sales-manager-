      "default": "\u0646\u0634\u0637",
      "description": "\u0627\u0644\u062d\u0627\u0644\u0629"
    },
    "commission_rate": {
      "type": "number",
      "description": "\u0646\u0633\u0628\u0629 \u0627\u0644\u0639\u0645\u0648\u0644\u0629 %"
